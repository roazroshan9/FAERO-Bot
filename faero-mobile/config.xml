<?xml version='1.0' encoding='utf-8'?>
<widget id="com.faero.bot"
        version="1.0.0"
        xmlns="http://www.w3.org/ns/widgets"
        xmlns:cdv="http://cordova.apache.org/ns/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android">

    <name>FaeroBot</name>
    <description>FAERO — Advanced AI Minecraft Bot Controller</description>
    <author email="admin@faero.bot" href="https://faero.bot">FAERO Team</author>

    <!-- Entry point -->
    <content src="index.html" />

    <!-- Allow all network access (Minecraft servers, local Node.js bridge) -->
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <!-- ── nodejs-mobile-cordova plugin ──────────────────────────────────── -->
    <!-- Run: cordova plugin add nodejs-mobile-cordova                       -->
    <plugin name="nodejs-mobile-cordova" spec="~0.3.5" />

    <!-- ── Android Platform ──────────────────────────────────────────────── -->
    <platform name="android">
        <allow-intent href="market:*" />

        <!-- Target API 33 (Android 13) — compatible with nodejs-mobile -->
        <preference name="android-compileSdkVersion" value="33" />
        <preference name="android-minSdkVersion"     value="24" />
        <preference name="android-targetSdkVersion"  value="33" />

        <!-- Keep screen on while bot is active -->
        <preference name="KeepRunning"    value="true" />
        <preference name="Orientation"    value="portrait" />
        <preference name="Fullscreen"     value="false" />
        <preference name="DisallowOverscroll" value="true" />

        <!-- WebView settings — needed for the inline dashboard -->
        <preference name="AllowInlineMediaPlayback"     value="true" />
        <preference name="AndroidInsecureFileModeAccess" value="true" />

        <!-- App icons (replace with your own in res/android/) -->
        <icon src="res/android/mipmap-mdpi/ic_launcher.png"    density="mdpi"    />
        <icon src="res/android/mipmap-hdpi/ic_launcher.png"    density="hdpi"    />
        <icon src="res/android/mipmap-xhdpi/ic_launcher.png"   density="xhdpi"   />
        <icon src="res/android/mipmap-xxhdpi/ic_launcher.png"  density="xxhdpi"  />
        <icon src="res/android/mipmap-xxxhdpi/ic_launcher.png" density="xxxhdpi" />

        <!-- Splash screens -->
        <splash src="res/android/drawable/splash.png" />

        <!-- AndroidManifest additions injected by Cordova -->
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.INTERNET" />
            <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
            <uses-permission android:name="android.permission.WAKE_LOCK" />
            <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
            <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
        </config-file>
    </platform>

    <!-- ── Global preferences ────────────────────────────────────────────── -->
    <preference name="CordovaWebViewEngine"     value="CDVUIWebViewEngine" />
    <preference name="SuppressesIncrementalRendering" value="false" />
    <preference name="AutoHideSplashScreen"     value="true" />
    <preference name="SplashScreenDelay"        value="1000" />
    <preference name="ShowSplashScreenSpinner"  value="false" />
    <preference name="FadeSplashScreen"         value="true" />
    <preference name="FadeSplashScreenDuration" value="300" />

</widget>
